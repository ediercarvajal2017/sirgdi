# SIRGDI v2.0 - Configuración de entorno
# Copia este archivo a .env y configura los valores para tu entorno

# === BASE DE DATOS ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sirgdi
DB_USER=root
DB_PASS=

# === SMTP (Correo) ===
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=tu_email@tudominio.com
SMTP_PASS=tu_contraseña_smtp
SMTP_FROM_EMAIL=noreply@tudominio.com
SMTP_FROM_NAME=SIRGDI - Reportes de Daños

# === SEGURIDAD ===
# Generar una clave de 32 bytes en hexadecimal:
# php -r 'echo bin2hex(random_bytes(32));'
ENCRYPTION_KEY=a7f3b9c2e1d4f6a8b5c3e9d2f1a8b4c7e6d9f2a5b8c1e4f7a9d2c5e8b1f4a7

# JWT Secret (si se implementa autenticación basada en tokens)
JWT_SECRET=a1f3b9c2e1d4f6a8b5c3e9d2f1a8b4c7e6d9f2a5b8c1e4f7a9d2c5e8b1f4a7

# CSRF Salt
CSRF_SALT=a2f3b9c2e1d4f6a8b5c3e9d2f1a8b4c7

# === APLICACIÓN ===
ENV=development
DEBUG=false
APP_URL=http://localhost/reporte_danos

# Para producción en Hostinger, cambiar a:
# ENV=production
# DEBUG=false
# APP_URL=https://sirgdi.tudominio.com

# === TIMEZONE ===
# América/Bogotá para Colombia, América/Mexico_City para México, etc.
TIMEZONE=America/Bogota

# === HTTPS ===
# En desarrollo: false
# En producción: true
FORCE_HTTPS=false
