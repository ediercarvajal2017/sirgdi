# ============================================================
# SIRGDI v2.0 — Variables de entorno
# ============================================================
# 1) Copia este archivo a ".env" (en la RAÍZ del proyecto).
# 2) Completa los valores reales de tu hosting.
# 3) El archivo .env NUNCA se sube a git (está en .gitignore).
# ============================================================

# === BASE DE DATOS (datos que te da Hostinger en hPanel > Bases de datos MySQL) ===
DB_HOST=localhost
DB_PORT=3306
DB_NAME=uXXXXXXXX_sirgdi
DB_USER=uXXXXXXXX_admin
DB_PASS=PON_AQUI_LA_CONTRASENA_DE_LA_BD

# === SMTP (correo saliente — usa una cuenta de correo del dominio en Hostinger) ===
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=noreply@ediertech.com
SMTP_PASS=PON_AQUI_LA_CONTRASENA_DEL_CORREO
SMTP_FROM_EMAIL=noreply@ediertech.com
SMTP_FROM_NAME=SIRGDI - Reportes de Daños

# === SEGURIDAD ===
# Genera cada clave con:  php -r "echo bin2hex(random_bytes(32));"
ENCRYPTION_KEY=GENERA_UNA_CLAVE_DE_64_CARACTERES_HEX
JWT_SECRET=GENERA_OTRA_CLAVE_DE_64_CARACTERES_HEX
# CSRF Salt (16 bytes):  php -r "echo bin2hex(random_bytes(16));"
CSRF_SALT=GENERA_UNA_CLAVE_DE_32_CARACTERES_HEX

# === APLICACIÓN (PRODUCCIÓN) ===
ENV=production
DEBUG=false
APP_URL=https://mantenimiento.ediertech.com

# === ZONA HORARIA ===
TIMEZONE=America/Bogota

# === HTTPS (true en producción para cookies seguras) ===
FORCE_HTTPS=true
